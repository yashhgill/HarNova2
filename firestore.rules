rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Public test connection document
    match /test_harnova/{documentId} {
      allow read: if true;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Security constraints for user profiles
    match /users/{userId} {
      allow get: if isSignedIn(); // Allow reading profile
      allow list: if false; // Deny query scraping
      allow create: if isSignedIn() && isOwner(userId) 
                    && request.resource.data.tokens == 30 // Prevent self-awarding higher starting balances
                    && request.resource.data.email is string
                    && request.resource.data.uid == userId;
      
      allow update: if isSignedIn() && isOwner(userId)
                    && request.resource.data.email == resource.data.email // Email is immutable
                    && request.resource.data.uid == resource.data.uid // UID is immutable
                    && (
                      // Only allow altering tokens or metadata in logical, bounded increments
                      request.resource.data.tokens is int
                      && request.resource.data.tokens >= 0
                    );
      allow delete: if false; // Accounts cannot be arbitrary hard deleted via client SDK
    }

    // Websites configuration
    match /websites/{siteId} {
      // Free public read to anyone - this allows viewing/hosting websites!
      allow get: if true; 
      allow list: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid);

      allow create: if isSignedIn() 
                    && request.resource.data.ownerId == request.auth.uid
                    && request.resource.data.title is string && request.resource.data.title.size() <= 100
                    && request.resource.data.slug is string && request.resource.data.slug.size() <= 100
                    && request.resource.data.htmlContent is string && request.resource.data.htmlContent.size() <= 1000000; // Limit content size (max 1MB per document)
      
      allow update: if isSignedIn()
                    && resource.data.ownerId == request.auth.uid // Ownership check
                    && request.resource.data.ownerId == request.auth.uid // Lock owner ID
                    && (
                      // Either updating website metadata/code (affectedKeys bounds)
                      request.resource.data.title is string && request.resource.data.title.size() <= 100
                      && request.resource.data.htmlContent is string && request.resource.data.htmlContent.size() <= 1000000
                      // Or mapping custom domain
                      || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['customDomain', 'domainStatus']))
                    );

      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    // Transaction ledger logs (read-only for audit, create-only by authenticated users)
    match /transactions/{txId} {
      allow get: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow list: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      
      allow create: if isSignedIn() 
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.amount is int;
      allow update, delete: if false; // Transactions are immutable ledger entries
    }

    // Custom Domain configurations
    match /domains/{domainId} {
      allow get: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid);
      allow list: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid);
      
      allow create: if isSignedIn() 
                    && request.resource.data.ownerId == request.auth.uid
                    && isValidId(domainId)
                    && request.resource.data.domainName is string && request.resource.data.domainName.size() <= 100
                    && request.resource.data.status == "active";
                    
      allow update: if isSignedIn() 
                    && resource.data.ownerId == request.auth.uid 
                    && request.resource.data.ownerId == request.auth.uid
                    && (
                      // Only allow updating linkedSiteId or dnsRecords
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['dnsRecords', 'linkedSiteId'])
                    );
                    
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }
  }
}
